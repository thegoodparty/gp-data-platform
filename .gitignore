# code editors
.idea
.vscode
.DS_Store
*/.idea/
*/.vscode/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Python packaging artifacts
*.egg-info/

# Jupyter Notebook
.ipynb_checkpoints

# Airflow development files
airflow/logs

# Default .gitignore content added by dbt Cloud
# you shouldn't commit these into source control
# these are the default directory names, adjust/add to fit your needs
dbt/*/target/
dbt/*/dbt_packages/
dbt/*/logs/
dbt/project/dbt_internal_packages/
# end dbt Cloud content

# Virtual environments
.venv/

# Environment variables (only .env.example is committed)
.env
.env.local

# Genie export artifacts
genie/**/raw/
genie/**/redacted/
genie/**/metadata/

# CSVs written by scripts/ during local extract/load
tmp_data/

# Logs (including root level)
logs/

# Pre-commit cache
.pre-commit-cache/

# dbt logs generated by the l2-uniform-drift-remediator skill
# (the README is intentionally tracked, which also keeps the directory present)
.claude/skills/l2-uniform-drift-remediator/dbt_logs/*
!.claude/skills/l2-uniform-drift-remediator/dbt_logs/README.md

# Entity resolution local data and results (restricted data — never commit)
# Ad-hoc analysis notebooks + briefs are personal working experiments by
# default. Promote a specific analysis with `git add -f` if it should be
# team-shared. See the win-analytics-process skill's references/methodology.md
# ("Lightweight analysis pattern") for the convention.
analytics/ad_hoc/

# Calibration logs are personal per-session working documents — the durable
# lessons land in the skills + agent edits the log drives, not in the log
# itself. See the win-analytics-process skill's references/calibration.md for the convention.
analytics/runbook/CALIBRATION_*.md

# Entity resolution local data and results
entity_resolution/data/
entity_resolution/results/*.csv
