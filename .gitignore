# code editors
.idea
.vscode
.DS_Store
*/.idea/
*/.vscode/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Jupyter Notebook
.ipynb_checkpoints

# Airflow development files
airflow/logs

# Default .gitignore content added by dbt Cloud
# you shouldn't commit these into source control
# these are the default directory names, adjust/add to fit your needs
dbt/*/target/
dbt/*/dbt_packages/
dbt/*/logs/
dbt/project/dbt_internal_packages/
# end dbt Cloud content

# ignore .venv
.venv/

# Environment variables
.env
.env.local

# Genie export artifacts
genie/**/raw/
genie/**/redacted/
genie/**/metadata/

# ignore tmp_data
tmp_data/

# Logs (including root level) and things I don't want to commit
logs/

# Local dev files
.tickets/
.claude/skills/l2-uniform-drift-remediator/dbt_logs/*
!.claude/skills/l2-uniform-drift-remediator/dbt_logs/.gitkeep
!.claude/skills/l2-uniform-drift-remediator/dbt_logs/README.md
.pre-commit-cache/
.worktrees/
.playwright-cli/
test_data/
.databricks/

# Local-only project journals (per-contributor context for AI-assisted work)
analytics/*/SESSION_NOTES.md
analytics/*/WORKFLOW.md

# Analytics notebook scratch (checkpoints, ad-hoc files, sync/pull scripts that
# point at a per-contributor Databricks folder). The notebook itself is
# allow-listed below — using `**` instead of a trailing slash so the
# re-inclusion pattern works.
analytics/*/notebooks/**
!analytics/*/notebooks/*.ipynb

# Local-only shared analytics scripts (per-contributor Databricks sync/pull
# helpers that hardcode user-specific Workspace paths).
analytics/scripts/

# Per-contributor review sub-agents (kept local; project framing supplied at invocation)
.claude/agents/product-*.md

# Entity resolution local data and results
entity_resolution/data/
entity_resolution/results/*.csv

# Claude runbook (CLAUDE.md is intentionally tracked; this ignores legacy paths only)
.claude/RUNBOOK.md
