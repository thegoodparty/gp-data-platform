# code editors
.idea
.vscode
.DS_Store
*/.idea/
*/.vscode/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Jupyter Notebook
.ipynb_checkpoints

# Airflow development files
airflow/logs

# Default .gitignore content added by dbt Cloud
# you shouldn't commit these into source control
# these are the default directory names, adjust/add to fit your needs
dbt/*/target/
dbt/*/dbt_packages/
dbt/*/logs/
dbt/project/dbt_internal_packages/
# end dbt Cloud content

# ignore .venv
.venv/

# Environment variables
.env
.env.local

# Genie export artifacts
genie/**/raw/
genie/**/redacted/
genie/**/metadata/

# ignore tmp_data
tmp_data/

# Logs (including root level) and things I don't want to commit
logs/

# Local dev files
.tickets/
.claude/skills/l2-uniform-drift-remediator/dbt_logs/*
!.claude/skills/l2-uniform-drift-remediator/dbt_logs/.gitkeep
!.claude/skills/l2-uniform-drift-remediator/dbt_logs/README.md
.pre-commit-cache/
.worktrees/
.playwright-cli/
test_data/
.databricks/

# Local-only project journals (per-contributor context for AI-assisted work)
analytics/projects/*/SESSION_NOTES.md
analytics/projects/*/WORKFLOW.md

# Scouting / inventory deliverables are drafted locally and synced to the
# ClickUp product-analytics doc instead of being committed here.
analytics/projects/*/INVENTORY.md

# Analytics notebooks are per-contributor working artifacts. The durable
# knowledge is promoted to the runbook + the ClickUp product-analytics doc, not
# committed (same paradigm as INVENTORY.md / SESSION_NOTES.md). Keep them local.
analytics/projects/*/notebooks/**

# Scout project dependency pins are local working artifacts too.
analytics/projects/*/requirements.txt

# Ad-hoc analysis notebooks + briefs are personal working experiments by
# default. Promote a specific analysis with `git add -f` if it should be
# team-shared. See win.md §7 "Lightweight analysis pattern" for the convention.
analytics/ad_hoc/

# Calibration logs are personal per-session working documents — the durable
# lessons land in the runbook + agent edits the log drives, not in the log
# itself. See win.md §9 "Calibration logs" for the convention.
analytics/runbook/CALIBRATION_*.md

# Per-contributor review sub-agent (PM agent kept local; project framing supplied at invocation)
.claude/agents/product-manager.md

# Entity resolution local data and results
entity_resolution/data/
entity_resolution/results/*.csv

# Claude runbook (CLAUDE.md is intentionally tracked; this ignores legacy paths only)
.claude/RUNBOOK.md
